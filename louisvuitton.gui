-- ================================================================
--  MOOZE UI  |  Kompletny Lua UI Framework
--  Styl: MOOZE (ciemne tlo, czerwony akcent, lewy sidebar,
--         gorne taby, sekcje MAIN/CHECKS/ACTIVATION)
--
--  JAK UZYWAC:
--    1. Podmien blok "DRAW API" na API swojego executora
--    2. Podmien blok "INPUT API" na API swojego executora
--    3. Zarejestruj on_draw() i on_tick() w swoim executorze
--    4. Dodawaj/usuwaj opcje edytujac tabele Menu.*
--
--  KOMPATYBILNOSC:
--    Synapse X, KRNL, Fluxus, ScriptWare, Wave
--    (lub dowolny executor z draw + input API)
-- ================================================================

-- ----------------------------------------------------------------
--  STYL  (wszystkie kolory i wymiary w jednym miejscu)
-- ----------------------------------------------------------------
local S = {
    -- Kolory {R,G,B,A}
    bg          = {26,  26,  26,  248},
    bg2         = {22,  22,  22,  255},
    bg3         = {16,  16,  16,  255},
    bg4         = {12,  12,  12,  255},
    accent      = {232, 64,  64,  255},   -- czerwony
    accent_dim  = {180, 40,  40,  200},
    border      = {38,  38,  38,  255},
    border2     = {28,  28,  28,  255},
    text        = {204, 204, 204, 255},
    text_dim    = {80,  80,  80,  255},
    text_bright = {238, 238, 238, 255},
    white       = {255, 255, 255, 255},
    sep         = {30,  30,  30,  255},

    -- Wymiary
    win_x        = 100,
    win_y        = 80,
    win_w        = 840,
    win_h        = 520,
    sidebar_w    = 180,
    topbar_h     = 42,
    padding      = 30,
    item_h       = 36,
    section_lbl  = 32,
}

-- ----------------------------------------------------------------
--  STATE
-- ----------------------------------------------------------------
local State = {
    visible      = true,
    dragging     = false,
    drag_ox      = 0,
    drag_oy      = 0,
    active_sec   = 1,   -- index aktywnej sekcji w sidebarze
    active_tab   = 1,   -- index aktywnego gornego taba
    open_dd      = nil, -- aktualnie otwarty dropdown
    binding      = nil, -- aktualnie bindowany keybind
    scroll_y     = 0,   -- scroll contentu
}

-- ================================================================
--  DANE MENU
--  Struktura:
--    Menu.sections = lista sekcji sidebarowych
--    Kazda sekcja ma: name, tabs[]
--    Kazdy tab ma: panels[] (lista sekcji MAIN/CHECKS/ACTIVATION)
--    Kazdy panel ma: title, items[]
--    Kazdy item ma: type + pola specyficzne dla danego typu
--
--  Typy itemow:
--    checkbox  – { type, label, value, callback }
--    slider    – { type, label, min, max, value, step, fmt, callback }
--    dropdown  – { type, label, options, value, callback }
--    toggle    – { type, label, value, callback }
--    keybind   – { type, label, key, callback }
--    multisel  – { type, label, options, values, callback }
--    button    – { type, label, callback }
-- ================================================================

local Menu = { sections = {} }

